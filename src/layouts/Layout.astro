---
import '@styles/global.css';
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#23252B" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500;600&display=swap"
		/>
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/icon32.png" />
		<link rel="icon" type="image/png" sizes="64x64" href="/icon64.png" />
		<link rel="icon" href="/favicon.ico" type="image/x-icon" />
		<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Raffaele Valenti - Lead Full-Stack Developer</title>
		<meta name="author" content="Raffaele Valenti" />
		<meta
			name="title"
			content="Raffaele Valenti - Lead Full-Stack Developer"
			data-react-helmet="true"
		/>
		<meta
			name="description"
			content={lang === 'it'
				? 'Lead Full-Stack Developer con 5+ anni su sistemi enterprise, consulenza e prodotto. React e TypeScript end-to-end, infrastruttura Docker/Kubernetes, e un game engine in Rust nel tempo libero.'
				: lang === 'fr'
					? 'Lead Full-Stack Developer avec 5+ ans sur des systèmes enterprise, consulting et produit. React et TypeScript de bout en bout, infrastructure Docker/Kubernetes, et un moteur de jeu en Rust en parallèle.'
					: 'Lead Full-Stack Developer with 5+ years across enterprise, consulting, and product. React and TypeScript end to end, Docker/Kubernetes infrastructure, and a game engine in Rust on the side.'}
			data-react-helmet="true"
		/>
		<meta
			name="keywords"
			content="Raffaele Valenti, full-stack developer, React, TypeScript, .NET, Docker, Kubernetes, Rust"
			data-react-helmet="true"
		/>
		<meta
			http-equiv="Content-Language"
			content={lang}
			data-react-helmet="true"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://raffaelevalenti.it/" />
		<meta
			property="og:title"
			content="Raffaele Valenti - Lead Full-Stack Developer"
			data-react-helmet="true"
		/>
		<meta
			property="og:description"
			content={lang === 'it'
				? 'Lead Full-Stack Developer con 5+ anni su sistemi enterprise, consulenza e prodotto. React e TypeScript end-to-end, infrastruttura Docker/Kubernetes, e un game engine in Rust nel tempo libero.'
				: lang === 'fr'
					? 'Lead Full-Stack Developer avec 5+ ans sur des systèmes enterprise, consulting et produit. React et TypeScript de bout en bout, infrastructure Docker/Kubernetes, et un moteur de jeu en Rust en parallèle.'
					: 'Lead Full-Stack Developer with 5+ years across enterprise, consulting, and product. React and TypeScript end to end, Docker/Kubernetes infrastructure, and a game engine in Rust on the side.'}
			data-react-helmet="true"
		/>
		<meta property="twitter:url" content="https://raffaelevalenti.it/" />
		<meta
			property="twitter:title"
			content="Raffaele Valenti - Lead Full-Stack Developer"
			data-react-helmet="true"
		/>
		<meta
			property="twitter:description"
			content={lang === 'it'
				? 'Lead Full-Stack Developer con 5+ anni su sistemi enterprise, consulenza e prodotto. React e TypeScript end-to-end, infrastruttura Docker/Kubernetes, e un game engine in Rust nel tempo libero.'
				: lang === 'fr'
					? 'Lead Full-Stack Developer avec 5+ ans sur des systèmes enterprise, consulting et produit. React et TypeScript de bout en bout, infrastructure Docker/Kubernetes, et un moteur de jeu en Rust en parallèle.'
					: 'Lead Full-Stack Developer with 5+ years across enterprise, consulting, and product. React and TypeScript end to end, Docker/Kubernetes infrastructure, and a game engine in Rust on the side.'}
			data-react-helmet="true"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>
<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
