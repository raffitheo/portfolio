---
import { getEntry } from 'astro:content';
import SkillRadarChart from './SkillRadarChart';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Radar } from 'lucide-astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get skills data from collections for current language
const skillCategoriesEntry = await getEntry('skillCategories', lang);
const skillCategories = skillCategoriesEntry?.data || [];
const sortedCategories = [...skillCategories].sort(
	(a, b) => (a.order || 0) - (b.order || 0),
);

// Get the radar data from collections for current language
const radarDataEntry = await getEntry('skillRadar', lang);
const radarData = radarDataEntry?.data || [];
const sortedRadarData = [...radarData].sort(
	(a, b) => (a.order || 0) - (b.order || 0),
);

// Transform radar data for the chart
const chartData = sortedRadarData.map((item) => ({
	subject: item.subject,
	A: item.value,
	fullMark: 100,
}));
---

<section id="skills" class="relative py-20">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-20 text-center">
			<h2 class="mb-6 text-3xl font-bold text-white md:text-5xl">
				{t('skills.title')}
			</h2>
			<div
				class="bg-accent mx-auto h-1 w-24 rounded-full shadow-[0_0_10px_rgba(152,164,181,0.5)]"
			>
			</div>
			<p class="text-secondary mx-auto mt-4 max-w-2xl">
				{t('skills.subtitle')}
			</p>
		</div>

		<div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-5">
			<div
				class="group bg-surface/40 hover:border-accent/30 hover:bg-surface/60 flex flex-col items-center justify-center overflow-hidden rounded-2xl border border-white/5 p-6 text-center shadow-lg backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_30px_-10px_rgba(0,0,0,0.5)] md:p-8 lg:col-span-2"
			>
				<div
					class="bg-accent/10 text-accent group-hover:bg-accent group-hover:text-background mb-4 rounded-xl p-4 transition-colors duration-300"
				>
					<Radar size={32} />
				</div>
				<h3
					class="group-hover:text-accent mb-2 text-xl font-bold text-white transition-colors"
				>
					{t('skills.radar.title')}
				</h3>
				<p
					class="text-secondary mb-4 text-sm transition-colors group-hover:text-gray-300"
				>
					{t('skills.radar.subtitle')}
				</p>

				<div class="w-full flex-1">
					<SkillRadarChart
						client:only="react"
						data={chartData}
						label={t('skills.proficiency.title')}
					/>
				</div>

				<div class="mt-4 flex flex-wrap justify-center gap-6">
					<div
						class="flex items-center gap-2.5 text-xs font-medium text-gray-400"
					>
						<span
							class="bg-accent h-2.5 w-2.5 rounded-full shadow-[0_0_8px_rgba(152,164,181,0.8)]"
						></span>
						{t('skills.radar.focus')}
					</div>
				</div>
			</div>

			<div class="space-y-8 lg:col-span-3">
				{
					sortedCategories.map((category) => (
						<div class="group bg-surface/40 hover:border-accent/30 hover:bg-surface/60 relative rounded-2xl border border-white/5 p-6 shadow-lg backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_30px_-10px_rgba(0,0,0,0.5)] md:p-8">
							<div class="mb-6 flex items-center justify-between">
								<div class="flex items-center gap-4">
									<h3 class="group-hover:text-accent text-xl font-bold text-white transition-colors">
										{category.name}
									</h3>
								</div>
								<span class="text-secondary font-mono text-xs font-semibold tracking-widest uppercase">
									{category.skills.length}{' '}
									{category.skills.length === 1 ? 'skill' : 'skills'}
								</span>
							</div>

							<div class="grid grid-cols-1 gap-x-10 gap-y-7 md:grid-cols-2">
								{category.skills.map(
									(skill: { name: string; level: number }) => (
										<div class="group/skill relative">
											<div class="mb-3 flex items-end justify-between">
												<span class="text-sm font-semibold tracking-wide text-gray-300 transition-colors group-hover/skill:text-white">
													{skill.name}
												</span>
												<span class="text-accent font-mono text-xs font-bold opacity-70 group-hover/skill:opacity-100">
													{skill.level}%
												</span>
											</div>

											<div class="bg-background/50 h-2.5 w-full overflow-hidden rounded-full border border-white/5 shadow-inner">
												<div
													class="bg-accent relative h-full rounded-full transition-all duration-1000 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:shadow-[0_0_15px_rgba(152,164,181,0.5)]"
													style={`--level: ${skill.level}%; width: 0;`}
													data-skill-bar
												>
													<div class="absolute inset-0 bg-linear-to-r from-transparent via-white/10 to-transparent opacity-0 transition-opacity group-hover/skill:animate-pulse group-hover/skill:opacity-100" />

													<div class="bg-accent/30 group-hover/skill:bg-accent/60 absolute top-1/2 right-0 h-4 w-4 translate-x-1/2 -translate-y-1/2 rounded-full blur-sm" />
												</div>
											</div>
										</div>
									),
								)}
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<script>
	const observerOptions = {
		threshold: 0.1,
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				entry.target.classList.add('is-visible');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	// Observe the Radar card
	const radarCard = document.querySelector('.lg\\:col-span-2');
	if (radarCard) observer.observe(radarCard);

	// Observe Category cards
	document.querySelectorAll('.lg\\:col-span-3 > div').forEach((card) => {
		observer.observe(card);
	});
</script>

<style>
	/* Custom transition for progress bars when they enter viewport */
	[data-skill-bar] {
		width: 0 !important;
		transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
	}

	:global(.is-visible) [data-skill-bar] {
		width: var(--level) !important;
	}
</style>
